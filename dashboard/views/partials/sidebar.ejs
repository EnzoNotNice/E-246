<aside class="app-sidebar" id="appSidebar">
    <div class="sidebar-content">
        <ul class="nav-menu">
            <li>
                <a href="/" class="nav-link <%= (typeof activeTab !== 'undefined' && activeTab === 'home') ? 'active' : '' %>">
                    <i class="fa-solid fa-house nav-icon"></i>
                    <span class="sidebar-text">الرئيسية</span>
                </a>
            </li>
            <% if (typeof user !== 'undefined' && user) { %>
                <li>
                    <a href="/dashboard" class="nav-link <%= (typeof activeTab !== 'undefined' && activeTab === 'servers') ? 'active' : '' %>">
                        <i class="fa-solid fa-server nav-icon"></i>
                        <span class="sidebar-text">قائمة السيرفرات</span>
                    </a>
                </li>
                <li>
                    <a href="/dashboard/admin/botsettings" class="nav-link <%= (typeof activeTab !== 'undefined' && activeTab === 'botsettings') ? 'active' : '' %>">
                        <i class="fa-solid fa-robot nav-icon"></i>
                        <span class="sidebar-text">إعدادات البوت</span>
                    </a>
                </li>
            <% } %>
        </ul>

        <% if (typeof guild !== 'undefined' && guild && guild.id) { %>
            <div class="nav-divider"><span class="sidebar-text">إعدادات السيرفر الحالي</span></div>

            <div class="active-server-widget">
                <% if (typeof guild.iconURL === 'function' && guild.iconURL()) { %>
                    <img src="<%= guild.iconURL() %>" alt="Guild Icon">
                <% } else if (guild.icon) { %>
                    <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" alt="Guild Icon">
                <% } else { %>
                    <div class="no-icon"><%= (guild.name || 'S').charAt(0) %></div>
                <% } %>
                <strong class="sidebar-text"><%= guild.name || 'Server' %></strong>
            </div>

            <ul class="nav-menu">
                <li>
                    <a href="/dashboard/<%= guild.id %>" class="nav-link <%= (typeof activeTab !== 'undefined' && activeTab === 'general') ? 'active' : '' %>">
                        <i class="fa-solid fa-sliders nav-icon"></i>
                        <span class="sidebar-text">الإعدادات العامة</span>
                    </a>
                </li>
                <li>
                    <a href="/dashboard/<%= guild.id %>/levels" class="nav-link <%= (typeof activeTab !== 'undefined' && activeTab === 'levels') ? 'active' : '' %>">
                        <i class="fa-solid fa-arrow-up-right-dots nav-icon"></i>
                        <span class="sidebar-text">المستويات</span>
                    </a>
                </li>
                <li>
                    <a href="/dashboard/<%= guild.id %>/welcome" class="nav-link <%= (typeof activeTab !== 'undefined' && activeTab === 'welcome') ? 'active' : '' %>">
                        <i class="fa-solid fa-handshake nav-icon"></i>
                        <span class="sidebar-text">الترحيب</span>
                    </a>
                </li>
                <li>
                    <a href="/dashboard/<%= guild.id %>/protection" class="nav-link <%= (typeof activeTab !== 'undefined' && activeTab === 'protection') ? 'active' : '' %>">
                        <i class="fa-solid fa-shield-halved nav-icon"></i>
                        <span class="sidebar-text">الحماية</span>
                    </a>
                </li>
                <li>
                    <a href="/dashboard/<%= guild.id %>/automod" class="nav-link <%= (typeof activeTab !== 'undefined' && activeTab === 'automod') ? 'active' : '' %>">
                        <i class="fa-solid fa-comment-slash nav-icon"></i>
                        <span class="sidebar-text">الفلتر الذكي</span>
                    </a>
                </li>
                <li>
                    <a href="/dashboard/<%= guild.id %>/tempvoice" class="nav-link <%= (typeof activeTab !== 'undefined' && activeTab === 'tempvoice') ? 'active' : '' %>">
                        <i class="fa-solid fa-microphone-lines nav-icon"></i>
                        <span class="sidebar-text">الغرف المؤقتة</span>
                    </a>
                </li>
                <li>
                    <a href="/dashboard/<%= guild.id %>/alerts" class="nav-link <%= (typeof activeTab !== 'undefined' && activeTab === 'alerts') ? 'active' : '' %>">
                        <i class="fa-brands fa-youtube nav-icon"></i>
                        <span class="sidebar-text">تنبيهات المحتوى</span>
                    </a>
                </li>
                <li>
                    <a href="/dashboard/<%= guild.id %>/autoreplies" class="nav-link <%= (typeof activeTab !== 'undefined' && activeTab === 'autoreplies') ? 'active' : '' %>">
                        <i class="fa-solid fa-reply-all nav-icon"></i>
                        <span class="sidebar-text">الردود التلقائية</span>
                    </a>
                </li>
                <li>
                    <a href="/dashboard/<%= guild.id %>/aliases" class="nav-link <%= (typeof activeTab !== 'undefined' && activeTab === 'aliases') ? 'active' : '' %>">
                        <i class="fa-solid fa-link nav-icon"></i>
                        <span class="sidebar-text">اختصارات الأوامر</span>
                    </a>
                </li>
                <li>
                    <a href="/dashboard/<%= guild.id %>/logs" class="nav-link <%= (typeof activeTab !== 'undefined' && activeTab === 'logs') ? 'active' : '' %>">
                        <i class="fa-solid fa-clipboard-list nav-icon"></i>
                        <span class="sidebar-text">سجلات الأحداث</span>
                    </a>
                </li>
                <li>
                    <a href="/dashboard/<%= guild.id %>/tickets" class="nav-link <%= (typeof activeTab !== 'undefined' && activeTab === 'tickets') ? 'active' : '' %>">
                        <i class="fa-solid fa-ticket nav-icon"></i>
                        <span class="sidebar-text">التذاكر</span>
                    </a>
                </li>
                <li>
                    <a href="/dashboard/<%= guild.id %>/embed" class="nav-link <%= (typeof activeTab !== 'undefined' && activeTab === 'embed') ? 'active' : '' %>">
                        <i class="fa-solid fa-paintbrush nav-icon"></i>
                        <span class="sidebar-text">صانع الإمبيد</span>
                    </a>
                </li>
                <li>
                    <a href="/dashboard/<%= guild.id %>/stats" class="nav-link <%= (typeof activeTab !== 'undefined' && activeTab === 'stats') ? 'active' : '' %>">
                        <i class="fa-solid fa-chart-column nav-icon"></i>
                        <span class="sidebar-text">الإحصائيات</span>
                    </a>
                </li>

                <li class="nav-divider"><span class="sidebar-text">أدوات متقدمة</span></li>
                <li>
                    <a href="/dashboard/<%= guild.id %>/reactionroles" class="nav-link <%= (typeof activeTab !== 'undefined' && activeTab === 'reactionroles') ? 'active' : '' %>">
                        <i class="fa-solid fa-masks-theater nav-icon"></i>
                        <span class="sidebar-text">التفاعل بالرتب</span>
                    </a>
                </li>
                <li>
                    <a href="/dashboard/<%= guild.id %>/forms" class="nav-link <%= (typeof activeTab !== 'undefined' && activeTab === 'forms') ? 'active' : '' %>">
                        <i class="fa-solid fa-clipboard-question nav-icon"></i>
                        <span class="sidebar-text">نظام التقديمات</span>
                    </a>
                </li>
                <li>
                    <a href="/dashboard/<%= guild.id %>/captcha" class="nav-link <%= (typeof activeTab !== 'undefined' && activeTab === 'captcha') ? 'active' : '' %>">
                        <i class="fa-solid fa-shield-cat nav-icon"></i>
                        <span class="sidebar-text">التحقق البشري</span>
                    </a>
                </li>
                <li>
                    <a href="/dashboard/<%= guild.id %>/customcmds" class="nav-link <%= (typeof activeTab !== 'undefined' && activeTab === 'customcmds') ? 'active' : '' %>">
                        <i class="fa-solid fa-wand-magic-sparkles nav-icon"></i>
                        <span class="sidebar-text">الأوامر المخصصة</span>
                    </a>
                </li>
            </ul>
        <% } %>
    </div>

    <div class="sidebar-footer">
        <% if (typeof user !== 'undefined' && user) { %>
            <div class="user-profile-widget">
                <img src="<%= user.avatar ? ('https://cdn.discordapp.com/avatars/' + user.id + '/' + user.avatar + '.png') : '/images/default-avatar.png' %>" alt="Avatar">
                <div class="user-profile-info sidebar-text">
                    <span><%= user.username || 'User' %></span>
                    <small>المشرف العام</small>
                </div>
            </div>
            <a href="/auth/logout" class="btn btn-danger logout-btn" title="تسجيل الخروج">
                <i class="fa-solid fa-right-from-bracket"></i>
                <span class="sidebar-text">تسجيل الخروج</span>
            </a>
        <% } else { %>
            <a href="/auth/login" class="btn btn-primary login-btn btn-block">
                <i class="fa-brands fa-discord"></i>
                <span class="sidebar-text">تسجيل الدخول</span>
            </a>
        <% } %>
    </div>
</aside>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const sidebarContent = document.querySelector('.sidebar-content');
        if (sidebarContent) {
            const savedScroll = sessionStorage.getItem('sidebarScrollPos');
            if (savedScroll !== null) {
                sidebarContent.scrollTop = parseInt(savedScroll, 10);
            }
            window.addEventListener('beforeunload', () => {
                sessionStorage.setItem('sidebarScrollPos', sidebarContent.scrollTop);
            });
            sidebarContent.addEventListener('scroll', () => {
                sessionStorage.setItem('sidebarScrollPos', sidebarContent.scrollTop);
            });
        }
    });
</script>
