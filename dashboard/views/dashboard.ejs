<%- include('partials/header') %>
<%
guilds = typeof guilds !== 'undefined' && Array.isArray(guilds) ? guilds : [];
botGuilds = typeof botGuilds !== 'undefined' && botGuilds ? botGuilds : new Set();
stats = typeof stats !== 'undefined' && stats ? stats : { totalGuilds: 0, uptime: '0s', ping: '0ms' };
user = typeof user !== 'undefined' ? user : null;
%>
<%- include('partials/sidebar', { activeTab: 'servers' }) %>

<main class="app-content">

    <!-- Page Header -->
    <div class="content-header">
        <h1><i class="fa-solid fa-server"></i> لوحة التحكم</h1>
        <p>تحكم في إعدادات البوت عبر جميع سيرفراتك بكل سهولة واحترافية</p>
    </div>

    <!-- Stats Row -->
    <div class="bento-grid cols-4" style="margin-bottom: 28px;">

        <!-- السيرفرات المتاحة -->
        <div class="glass-panel reveal metric-card">
            <div class="metric-icon">
                <i class="fa-solid fa-server"></i>
            </div>
            <div class="metric-value" data-count="<%= guilds.length %>"><%= guilds.length %></div>
            <div class="metric-label">سيرفراتك</div>
        </div>

        <!-- سيرفرات البوت -->
        <div class="glass-panel reveal metric-card">
            <div class="metric-icon">
                <i class="fa-solid fa-globe"></i>
            </div>
            <div class="metric-value" data-count="<%= typeof stats !== 'undefined' ? stats.totalGuilds : botGuilds.size %>"><%= typeof stats !== 'undefined' ? stats.totalGuilds : botGuilds.size %></div>
            <div class="metric-label">سيرفرات البوت الكلية</div>
        </div>

        <!-- مدة التشغيل -->
        <div class="glass-panel reveal metric-card">
            <div class="metric-icon">
                <i class="fa-solid fa-clock-rotate-left"></i>
            </div>
            <div class="metric-value uptime-display" style="font-size: 1.2rem; line-height: 1.3; margin-top: 4px;">
                <%= typeof stats !== 'undefined' ? stats.uptime : '—' %>
            </div>
            <div class="metric-label">مدة التشغيل</div>
        </div>

        <!-- البينج -->
        <div class="glass-panel reveal metric-card">
            <div class="metric-icon">
                <i class="fa-solid fa-signal"></i>
            </div>
            <div class="metric-value" style="font-size: 1.4rem;">
                <%= typeof stats !== 'undefined' ? stats.ping : '—' %>
            </div>
            <div class="metric-label">البينج (Ping)</div>
        </div>

    </div>

    <!-- Divider Label -->
    <% if (guilds.length > 0) { %>
    <div class="section-divider reveal">
        <span>السيرفرات المتاحة للإدارة</span>
    </div>
    <% } %>

    <!-- Guild Cards -->
    <% if (guilds.length > 0) { %>
    <div class="guild-grid reveal">
        <% guilds.forEach(guild => { %>
            <% const isBotInGuild = botGuilds.has(guild.id); %>
            <div class="glass-panel reveal guild-card">
                <div class="guild-icon-wrapper">
                    <% if (guild.icon) { %>
                        <img
                            src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png?size=128"
                            alt="<%= guild.name %>"
                            loading="lazy"
                            class="guild-icon"
                        >
                    <% } else { %>
                        <div class="no-icon guild-icon"><%= guild.name.charAt(0).toUpperCase() %></div>
                    <% } %>
                </div>

                <h3 title="<%= guild.name %>" class="guild-name"><%= guild.name %></h3>

                <% if (isBotInGuild) { %>
                    <a href="/dashboard/<%= guild.id %>" class="btn btn-primary btn-large" style="width: 100%; margin-top: auto;">
                        <i class="fa-solid fa-sliders"></i> إدارة السيرفر
                    </a>
                <% } else { %>
                    <span class="btn btn-secondary btn-large disabled" style="opacity:0.35; cursor:not-allowed; width: 100%; margin-top: auto;">
                        <i class="fa-solid fa-robot"></i> البوت غير موجود
                    </span>
                <% } %>
            </div>
        <% }) %>
    </div>
    <% } else { %>
    <!-- Empty State -->
    <div class="glass-panel reveal empty-state">
        <div class="empty-icon"><i class="fa-solid fa-triangle-exclamation"></i></div>
        <h2>لا يوجد سيرفرات متاحة</h2>
        <p>ليس لديك صلاحيات إدارية في أي سيرفر متواجد فيه البوت حالياً</p>
    </div>
    <% } %>

</main>

<style>
/* Section divider */
.section-divider {
    display: flex;
    align-items: center;
    gap: 14px;
    margin: 0 0 20px;
    color: var(--text-3);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
}
.section-divider::before,
.section-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
}

/* Empty state */
.empty-state {
    text-align: center;
    padding: 60px 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
}
.empty-state .empty-icon {
    font-size: 3rem;
    color: var(--text-3);
    margin-bottom: 18px;
    line-height: 1;
}
.empty-state h2 {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-1);
    margin-bottom: 10px;
}
.empty-state p {
    color: var(--text-2);
    font-size: 0.9rem;
    max-width: 360px;
    margin: 0 auto;
    line-height: 1.6;
}

/* Uptime metric value */
.uptime-display {
    font-variant-numeric: tabular-nums;
    direction: ltr;
}

/* Typography & Transitions Improvements */
.guild-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 24px;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    gap: 16px;
    min-height: 260px;
}

.guild-card:hover {
    transform: translateY(-5px);
    border-color: rgba(255, 255, 255, 0.1);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
}

.guild-icon-wrapper {
    margin-bottom: 8px;
}

.guild-icon {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--border);
    transition: border-color 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    font-weight: bold;
    color: var(--text-1);
    background: rgba(255, 255, 255, 0.05);
}

.guild-card:hover .guild-icon {
    border-color: var(--primary);
}

.guild-name {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-1);
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    width: 100%;
}

.metric-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 24px;
    transition: transform 0.3s ease, border-color 0.3s ease;
}

.metric-card:hover {
    transform: translateY(-5px);
    border-color: rgba(255, 255, 255, 0.1);
}
</style>

<%- include('partials/footer') %>
